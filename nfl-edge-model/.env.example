# Copy this file to .env for local reference only.
# Actual values are never committed — local dev pulls real values via
# `doppler run -- <command>`, production pulls them from GitHub Actions secrets.

# Odds API (halves/quarters lines, live multi-book pricing, line movement)
ODDS_API_KEY=

# Supabase (Postgres data layer)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_PASSWORD=

# Gmail SMTP (text/email alerts)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# SMS-to-email gateway for text alerts (e.g. yournumber@vtext.com)
SMS_GATEWAY_ADDRESS=
